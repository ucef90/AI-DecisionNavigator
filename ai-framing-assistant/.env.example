# AI Decision Navigator — environment variables reference.
#
# Copy this file to `.env` (for local dev) or set the variables in your
# orchestrator (Vercel project settings, docker-compose `environment:`,
# Kubernetes secrets…).

# -------------------------------------------------------------
# Database
# -------------------------------------------------------------
# Two schemes are supported by lib/prisma.ts:
#
#   - file:./prisma/dev.db                      → SQLite (zero-setup dev)
#   - postgresql://USER:PASS@HOST:PORT/DB       → PostgreSQL (Docker / prod)
DATABASE_URL="file:./prisma/dev.db"

# -------------------------------------------------------------
# Docker Compose only — picked up by docker-compose.yml
# -------------------------------------------------------------
POSTGRES_USER=ain
POSTGRES_PASSWORD=ain_local_dev_password
POSTGRES_DB=ai_navigator
DB_PORT=5433
APP_PORT=3000

# Set to "true" on first container boot to seed the 3 SPEC demo projects.
SEED_DEMO=true

# -------------------------------------------------------------
# LLM provider (placeholders — wired in once the provider
# abstraction lands).
# -------------------------------------------------------------
# AI_PROVIDER=openai          # openai | azure | mistral | ollama
# AI_BASE_URL=                # https://api.openai.com/v1, https://YOUR-AZURE.openai.azure.com/, http://ollama:11434/v1
# AI_MODEL=gpt-4o-mini        # gpt-4o-mini, mistral-large, llama3.1...
# AI_API_KEY=                 # required for cloud providers
# AI_AZURE_DEPLOYMENT=        # Azure OpenAI deployment name
# AI_AZURE_API_VERSION=2024-08-01-preview

# -------------------------------------------------------------
# Misc
# -------------------------------------------------------------
# NEXT_TELEMETRY_DISABLED=1
# NODE_ENV=production
